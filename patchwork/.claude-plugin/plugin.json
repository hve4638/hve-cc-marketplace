{
  "name": "patchwork",
  "version": "0.2.0",
  "description": "Code-work methodology guardrail for context preservation — CONTEXT.md, WHY: comments, domain terms",
  "author": {
    "name": "Hve"
  },
  "license": "MIT",
  "keywords": [
    "claude-code",
    "plugin",
    "methodology",
    "guardrails"
  ],
  "skills": "./skills/",
  "mcpServers": "./.mcp.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PLUGIN_ROOT\"/scripts/pretool-hook.mjs",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PLUGIN_ROOT\"/scripts/posttool-hook.mjs",
            "timeout": 3
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PLUGIN_ROOT\"/scripts/postcompact-hook.mjs",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PLUGIN_ROOT\"/scripts/stop-hook.mjs",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
