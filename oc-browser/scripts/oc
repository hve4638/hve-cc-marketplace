#!/usr/bin/env bash
# oc — native passthrough to `openclaw browser` for already-isolated environments.
#
# Use this when Claude is already running inside a container (or another
# isolation boundary) and another Docker layer would be overkill / impossible.
# `oc-as` is the right choice everywhere else.
#
# Behavior:
#   • If /.dockerenv is missing, prints a host-environment warning and sleeps 3s
#     before forwarding. Set OC_NO_HOST_WARN=1 to silence.
#   • Verifies `npx` and a Chromium binary are reachable on PATH for non-readonly
#     calls; bails with install hints otherwise.
#   • Forwards all args to `npx -y openclaw@$OC_PIN` (default pinned version
#     overridable via the OC_PIN env var on the host).
set -Eeuo pipefail

OC_PIN="${OC_PIN:-2026.4.27}"

is_readonly_call() {
  [[ $# -eq 0 ]] && return 0
  case "$1" in
    --help|-h|help|--version|-v) return 0 ;;
  esac
  return 1
}

if ! is_readonly_call "$@"; then
  if [[ ! -e /.dockerenv && -z "${OC_NO_HOST_WARN:-}" ]]; then
    echo "oc: WARNING — /.dockerenv 없음. 호스트 환경에서 실행 중입니다." >&2
    echo "oc: 격리 없이 npx openclaw가 직접 동작합니다. 의도한 게 아니라면 Ctrl-C 후 oc-as를 쓰세요." >&2
    echo "oc: 끄려면 OC_NO_HOST_WARN=1." >&2
    sleep 3
  fi
fi

if ! command -v npx >/dev/null 2>&1; then
  echo "oc: ERROR — npx가 PATH에 없습니다. Node.js를 설치하세요." >&2
  echo "  Debian/Ubuntu: apt-get install -y nodejs npm" >&2
  echo "  RHEL/Fedora:   dnf install -y nodejs npm" >&2
  echo "  macOS:         brew install node" >&2
  exit 127
fi

if ! is_readonly_call "$@"; then
  if ! command -v chromium        >/dev/null 2>&1 \
  && ! command -v chromium-browser >/dev/null 2>&1 \
  && ! command -v google-chrome    >/dev/null 2>&1; then
    echo "oc: ERROR — Chromium이 PATH에 없습니다." >&2
    echo "  Debian/Ubuntu: apt-get install -y chromium" >&2
    echo "  RHEL/Fedora:   dnf install -y chromium" >&2
    echo "  macOS:         brew install --cask chromium  (또는 google-chrome)" >&2
    exit 127
  fi
fi

exec npx -y "openclaw@${OC_PIN}" "$@"
