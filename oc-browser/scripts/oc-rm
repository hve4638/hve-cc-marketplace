#!/usr/bin/env bash
# oc-rm — remove oc-browser instance(s) for the current project.
#
# Default: stop+rm the container, rm the docker home volume (cookies/profile).
# Host-side .agent-memory/oc-volume/<resolved>/ is preserved unless --rm-shared.
#
# <name> forms mirror oc-as:
#   <rest>                exact (plain mode)
#   host:<rest>           → host_<rest>
#   vnc:<port>:<rest>     → vnc_<port>_<rest>
#   vnc:<rest>            → vnc_*_<rest>   (any port; matches all)
set -Eeuo pipefail

usage() {
  cat <<'EOF'
usage: oc-rm [flags] <name>...
       oc-rm [flags] --all

Remove oc-browser instance(s) in the current project. Container + docker
home volume by default. Host-side .agent-memory/oc-volume/<resolved>/ is
preserved unless --rm-shared is set.

<name> forms (same as oc-as):
  <rest>              exact (plain mode)
  host:<rest>         host_<rest>
  vnc:<port>:<rest>   vnc_<port>_<rest>
  vnc:<rest>          vnc_*_<rest>   (any port — matches all)

Flags:
  -f, --force         skip the y/N confirmation
      --keep-volume   keep the docker home volume (cookies/profile)
      --rm-shared     also rm -rf .agent-memory/oc-volume/<resolved>/
      --all           every oc-browser-<projTag>-* in this project
  -h, --help          this help

Examples:
  oc-rm host:work
  oc-rm vnc:work                     # all ports for 'work'
  oc-rm -f --rm-shared host:demo
  oc-rm --all
EOF
}

FORCE=0
KEEP_VOLUME=0
RM_SHARED=0
ALL=0
PATTERNS=()

while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help)        usage; exit 0 ;;
    -f|--force)       FORCE=1; shift ;;
    --keep-volume)    KEEP_VOLUME=1; shift ;;
    --rm-shared)      RM_SHARED=1; shift ;;
    --all)            ALL=1; shift ;;
    --)               shift; while [ $# -gt 0 ]; do PATTERNS+=("$1"); shift; done ;;
    -*)               echo "oc-rm: unknown flag '$1'" >&2; exit 2 ;;
    *)                PATTERNS+=("$1"); shift ;;
  esac
done

if [ "$ALL" = 1 ] && [ "${#PATTERNS[@]}" -gt 0 ]; then
  echo "oc-rm: --all is exclusive with explicit names" >&2
  exit 2
fi
if [ "$ALL" != 1 ] && [ "${#PATTERNS[@]}" -eq 0 ]; then
  usage >&2; exit 2
fi

find_volume_root() {
  local d="$PWD"
  while [ "$d" != "/" ]; do
    if [ -d "$d/.agent-memory/oc-volume" ]; then
      printf '%s\n' "$d/.agent-memory/oc-volume"
      return 0
    fi
    d="$(dirname "$d")"
  done
  return 1
}

if ! VOLUME_ROOT="$(find_volume_root)"; then
  echo "oc-rm: no .agent-memory/oc-volume/ found from $PWD upward" >&2
  exit 1
fi
PROJECT_ROOT="$(dirname "$(dirname "$VOLUME_ROOT")")"

project_tag() {
  local t
  t="$(basename "$PROJECT_ROOT")"
  t="${t,,}"
  t="$(printf '%s' "$t" | tr -c 'a-z0-9_.-' '-' | sed -E 's/-+/-/g; s/^-+//; s/-+$//')"
  t="${t:0:16}"
  printf '%s' "${t:-root}"
}
PROJTAG="$(project_tag)"
PREFIX="oc-browser-${PROJTAG}-"

valid_rest() {
  [[ "$1" =~ ^[a-zA-Z0-9][a-zA-Z0-9_.-]{0,24}$ ]]
}

exists_anywhere() {
  local n="$1"
  local c="${PREFIX}${n}"
  local v="oc-browser-home-${PROJTAG}-${n}"
  local s="${VOLUME_ROOT}/${n}"
  docker inspect "$c" >/dev/null 2>&1 && return 0
  docker volume inspect "$v" >/dev/null 2>&1 && return 0
  [ -d "$s" ] && return 0
  return 1
}

resolved=()

if [ "$ALL" = 1 ]; then
  while IFS= read -r c; do
    [ -z "$c" ] && continue
    resolved+=("${c#$PREFIX}")
  done < <(docker ps -a --filter "name=^${PREFIX}" --format '{{.Names}}' 2>/dev/null)
  # Also pick up containerless leftovers (volumes / shared dirs).
  while IFS= read -r v; do
    [ -z "$v" ] && continue
    n="${v#oc-browser-home-${PROJTAG}-}"
    [ "$n" = "$v" ] && continue
    resolved+=("$n")
  done < <(docker volume ls --filter "name=^oc-browser-home-${PROJTAG}-" --format '{{.Name}}' 2>/dev/null)
  if [ -d "$VOLUME_ROOT" ]; then
    while IFS= read -r d; do
      [ -z "$d" ] && continue
      resolved+=("$(basename "$d")")
    done < <(find "$VOLUME_ROOT" -mindepth 1 -maxdepth 1 -type d 2>/dev/null)
  fi
else
  for pat in "${PATTERNS[@]}"; do
    matched=0
    case "$pat" in
      host:*)
        rest="${pat#host:}"
        valid_rest "$rest" || { echo "oc-rm: invalid name body '$rest'" >&2; exit 2; }
        n="host_${rest}"
        if exists_anywhere "$n"; then resolved+=("$n"); matched=1; fi
        ;;
      vnc:*:*)
        rest_raw="${pat#vnc:}"
        if [[ "$rest_raw" =~ ^([0-9]+):(.+)$ ]]; then
          port="${BASH_REMATCH[1]}"
          rest="${BASH_REMATCH[2]}"
          valid_rest "$rest" || { echo "oc-rm: invalid name body '$rest'" >&2; exit 2; }
          n="vnc_${port}_${rest}"
          if exists_anywhere "$n"; then resolved+=("$n"); matched=1; fi
        else
          echo "oc-rm: malformed '$pat'" >&2; exit 2
        fi
        ;;
      vnc:*)
        rest="${pat#vnc:}"
        valid_rest "$rest" || { echo "oc-rm: invalid name body '$rest'" >&2; exit 2; }
        # glob: vnc_<digits>_<rest>
        while IFS= read -r c; do
          [ -z "$c" ] && continue
          n="${c#$PREFIX}"
          if [[ "$n" =~ ^vnc_[0-9]+_${rest}$ ]]; then
            resolved+=("$n"); matched=$((matched+1))
          fi
        done < <(docker ps -a --filter "name=^${PREFIX}vnc_" --format '{{.Names}}' 2>/dev/null)
        # Also catch leftover dirs/volumes for stopped+removed containers.
        while IFS= read -r v; do
          [ -z "$v" ] && continue
          n="${v#oc-browser-home-${PROJTAG}-}"
          [ "$n" = "$v" ] && continue
          if [[ "$n" =~ ^vnc_[0-9]+_${rest}$ ]]; then
            resolved+=("$n"); matched=$((matched+1))
          fi
        done < <(docker volume ls --filter "name=^oc-browser-home-${PROJTAG}-vnc_" --format '{{.Name}}' 2>/dev/null)
        if [ -d "$VOLUME_ROOT" ]; then
          while IFS= read -r d; do
            [ -z "$d" ] && continue
            n="$(basename "$d")"
            if [[ "$n" =~ ^vnc_[0-9]+_${rest}$ ]]; then
              resolved+=("$n"); matched=$((matched+1))
            fi
          done < <(find "$VOLUME_ROOT" -mindepth 1 -maxdepth 1 -type d 2>/dev/null)
        fi
        ;;
      *)
        valid_rest "$pat" || { echo "oc-rm: invalid name '$pat'" >&2; exit 2; }
        if exists_anywhere "$pat"; then resolved+=("$pat"); matched=1; fi
        ;;
    esac
    if [ "$matched" = 0 ]; then
      echo "oc-rm: '$pat' matched no container/volume/dir in project '$PROJTAG'" >&2
      exit 1
    fi
  done
fi

# Dedupe.
if [ "${#resolved[@]}" -gt 0 ]; then
  IFS=$'\n' read -r -d '' -a resolved < <(printf '%s\n' "${resolved[@]}" | awk '!seen[$0]++' && printf '\0') || true
fi

if [ "${#resolved[@]}" -eq 0 ]; then
  echo "oc-rm: nothing to remove in project '$PROJTAG'" >&2
  exit 1
fi

echo "Project: $PROJTAG"
echo "Targets:"
for n in "${resolved[@]}"; do
  c="${PREFIX}${n}"
  v="oc-browser-home-${PROJTAG}-${n}"
  s="${VOLUME_ROOT}/${n}"
  flags=()
  docker inspect "$c"        >/dev/null 2>&1 && flags+=("container")
  docker volume inspect "$v" >/dev/null 2>&1 && {
    if [ "$KEEP_VOLUME" = 1 ]; then flags+=("volume kept"); else flags+=("volume"); fi
  }
  [ -d "$s" ] && {
    if [ "$RM_SHARED" = 1 ]; then flags+=("shared"); else flags+=("shared kept"); fi
  }
  printf '  %-44s  [%s]\n' "$c" "$(IFS=','; echo "${flags[*]:-nothing}")"
done

if [ "$FORCE" != 1 ]; then
  read -r -p "Proceed? [y/N] " ans
  case "$ans" in y|Y|yes|YES) ;; *) echo "aborted"; exit 0 ;; esac
fi

fail=0
for n in "${resolved[@]}"; do
  c="${PREFIX}${n}"
  v="oc-browser-home-${PROJTAG}-${n}"
  s="${VOLUME_ROOT}/${n}"

  if docker inspect "$c" >/dev/null 2>&1; then
    if docker rm -f "$c" >/dev/null 2>&1; then echo "[rm]  $c"; else echo "[rm]  $c FAILED"; fail=1; fi
  fi
  if [ "$KEEP_VOLUME" != 1 ] && docker volume inspect "$v" >/dev/null 2>&1; then
    if docker volume rm "$v" >/dev/null 2>&1; then echo "[vol] $v"; else echo "[vol] $v FAILED"; fail=1; fi
  fi
  if [ "$RM_SHARED" = 1 ] && [ -d "$s" ]; then
    if rm -rf "$s"; then echo "[dir] $s"; else echo "[dir] $s FAILED"; fail=1; fi
  fi
done

exit "$fail"
