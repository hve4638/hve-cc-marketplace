#!/usr/bin/env bash
# oc-list — show all oc-browser-* containers with their bind mounts.
#
# Output columns:
#   CONTAINER  -- name (oc-browser-<projTag>-<name>)
#   STATUS     -- docker state (running, exited, created, ...)
#   VOLUME     -- host path bound to /home/oc/shared inside the container
set -Eeuo pipefail

containers="$(docker ps -a --filter name=oc-browser- --format '{{.Names}}' 2>/dev/null || true)"

if [ -z "$containers" ]; then
  echo "(no oc-browser-* containers)"
  exit 0
fi

printf '%-44s  %-12s  %s\n' "CONTAINER" "STATUS" "VOLUME"
while IFS= read -r name; do
  [ -z "$name" ] && continue
  status="$(docker inspect -f '{{.State.Status}}' "$name" 2>/dev/null || echo '?')"
  bind="$(docker inspect --format \
    '{{range .Mounts}}{{if eq .Destination "/home/oc/shared"}}{{.Source}}{{end}}{{end}}' \
    "$name" 2>/dev/null || echo '')"
  printf '%-44s  %-12s  %s\n' "$name" "$status" "${bind:-?}"
done <<< "$containers"
