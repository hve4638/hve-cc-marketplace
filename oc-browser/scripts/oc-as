#!/usr/bin/env bash
# oc-as — drive an isolated headed Chromium via container `oc-browser-<projTag>-<name>`.
#
# Volume:    walks up from PWD to find `.agent-memory/oc-volume/`. If absent,
#            creates it at PWD. The volume root is per-project; the project's
#            basename becomes <projTag> in the container name (so the same
#            <name> in different projects → different containers).
# Lifecycle: container is created lazily on first call; persists until the
#            user explicitly removes it. Use `oc-list` to see what's alive.
# Cleanup:   manual.
#              docker rm -f       <container>
#              docker volume rm   oc-browser-home-<projTag>-<name>
#              rm -rf             .agent-memory/oc-volume/<name>
#
# Display modes (prefix on the name):
#   host:<rest>          render the container's Chromium directly on the host's
#                        X server. Uses $DISPLAY, falls back to :0 if /tmp/.X11-unix/X0
#                        exists. Fails with guidance if no host X is reachable.
#                        Container name: host_<rest>.
#   vnc:<rest>           bind the container's noVNC to a free host port (auto-picked
#                        from 6080-6099). Re-attaches to an existing vnc_*_<rest>
#                        container if present. Container name: vnc_<port>_<rest>.
#   vnc:<port>:<rest>    same, but request a specific port (1024-65535). Fails if
#                        the port is busy.
#   <name>               no display setup (headless gateway only). Existing behavior.
set -Eeuo pipefail

usage() {
  cat <<'EOF'
usage: oc-as <name> <openclaw-args...>

  <name>            instance name within the current project. May be prefixed:
                      host:<rest>           — render on host X (DISPLAY or :0)
                      vnc:<rest>            — VNC on a free port (6080-6099)
                      vnc:<port>:<rest>     — VNC on the given port
                      <rest>                — headless gateway only (legacy)
                    <rest> must match [a-zA-Z0-9][a-zA-Z0-9_.-]{0,24}.
                    Resolves to container 'oc-browser-<projTag>-<resolved>',
                    where <projTag> = basename of the project root that
                    holds .agent-memory/oc-volume/, and <resolved> is one of
                    host_<rest>, vnc_<port>_<rest>, or <rest>.
  <openclaw-args>   forwarded verbatim into the container.

examples:
  oc-as host:work browser open https://example.com --label demo
  oc-as vnc:work browser doctor
  oc-as vnc:5901:work browser status
  oc-as work browser doctor                 # headless, legacy

list active instances:  oc-list
remove one:             docker rm -f <container>   (see `oc-list`)
EOF
}

if [ $# -lt 1 ] || [[ "$1" == "--help" || "$1" == "-h" ]]; then
  usage
  [ $# -lt 1 ] && exit 2 || exit 0
fi

NAME_RAW="$1"; shift

# --- prefix parsing -----------------------------------------------------------
MODE=plain
PORT_REQ=""
PORT=""
REST=""

case "$NAME_RAW" in
  host:*)
    MODE=host
    REST="${NAME_RAW#host:}"
    ;;
  vnc:*)
    MODE=vnc
    rest_raw="${NAME_RAW#vnc:}"
    if [[ "$rest_raw" =~ ^([0-9]+):(.+)$ ]]; then
      PORT_REQ="${BASH_REMATCH[1]}"
      REST="${BASH_REMATCH[2]}"
    else
      PORT_REQ=auto
      REST="$rest_raw"
    fi
    ;;
  *)
    MODE=plain
    REST="$NAME_RAW"
    ;;
esac

if ! [[ "$REST" =~ ^[a-zA-Z0-9][a-zA-Z0-9_.-]{0,24}$ ]]; then
  echo "oc-as: invalid name body '$REST' (must match [a-zA-Z0-9][a-zA-Z0-9_.-]{0,24})" >&2
  exit 2
fi

if [ "$MODE" = "vnc" ] && [ "$PORT_REQ" != "auto" ]; then
  if ! [[ "$PORT_REQ" =~ ^[0-9]+$ ]] || [ "$PORT_REQ" -lt 1024 ] || [ "$PORT_REQ" -gt 65535 ]; then
    echo "oc-as: invalid VNC port '$PORT_REQ' (must be 1024-65535)" >&2
    exit 2
  fi
fi

# --- volume root & project tag ------------------------------------------------
find_volume_root() {
  local d="$PWD"
  while [ "$d" != "/" ]; do
    if [ -d "$d/.agent-memory/oc-volume" ]; then
      printf '%s\n' "$d/.agent-memory/oc-volume"
      return 0
    fi
    d="$(dirname "$d")"
  done
  return 1
}

if ! VOLUME_ROOT="$(find_volume_root)"; then
  VOLUME_ROOT="$PWD/.agent-memory/oc-volume"
  mkdir -p "$VOLUME_ROOT"
  echo "oc-as: created $VOLUME_ROOT" >&2
fi

PROJECT_ROOT="$(dirname "$(dirname "$VOLUME_ROOT")")"

project_tag() {
  local t
  t="$(basename "$PROJECT_ROOT")"
  t="${t,,}"
  t="$(printf '%s' "$t" | tr -c 'a-z0-9_.-' '-' | sed -E 's/-+/-/g; s/^-+//; s/-+$//')"
  t="${t:0:16}"
  printf '%s' "${t:-root}"
}

PROJTAG="$(project_tag)"

# --- helpers ------------------------------------------------------------------
port_is_free() {
  ! (echo > "/dev/tcp/127.0.0.1/$1") 2>/dev/null
}

find_free_port() {
  local p="$1" max="$2"
  while [ "$p" -le "$max" ]; do
    if port_is_free "$p"; then
      printf '%s' "$p"
      return 0
    fi
    p=$((p+1))
  done
  return 1
}

# --- mode resolution: container name + docker run flags -----------------------
MODE_FLAGS=()

case "$MODE" in
  plain)
    NAME="$REST"
    ;;

  host)
    HOST_DISPLAY="${DISPLAY:-}"
    if [ -z "$HOST_DISPLAY" ]; then
      if [ -S /tmp/.X11-unix/X0 ]; then
        HOST_DISPLAY=":0"
      else
        cat >&2 <<EOF
oc-as: host: mode needs a host X server but none was found.
  \$DISPLAY is unset and /tmp/.X11-unix/X0 does not exist.

Fix one of these and retry:
  - log in on the physical console so a graphical session runs as :0
  - export DISPLAY=:N pointing to an existing host X server
  - use 'vnc:${REST}' to view via noVNC instead
EOF
        exit 1
      fi
    fi
    disp="${HOST_DISPLAY#:}"; disp="${disp%%.*}"
    if [ ! -S "/tmp/.X11-unix/X${disp}" ]; then
      echo "oc-as: host: DISPLAY=$HOST_DISPLAY but /tmp/.X11-unix/X${disp} is missing" >&2
      exit 1
    fi
    NAME="host_${REST}"
    MODE_FLAGS=(-e "DISPLAY=$HOST_DISPLAY" -v /tmp/.X11-unix:/tmp/.X11-unix:ro)
    ;;

  vnc)
    existing="$(docker ps -a --filter "name=^oc-browser-${PROJTAG}-vnc_[0-9]+_${REST}$" --format '{{.Names}}' 2>/dev/null | head -1)"
    if [ -n "$existing" ]; then
      NAME="${existing#oc-browser-${PROJTAG}-}"
      PORT="$(docker port "$existing" 6080/tcp 2>/dev/null | head -1 | awk -F: '{print $NF}')"
    else
      if [ "$PORT_REQ" = "auto" ]; then
        if ! PORT="$(find_free_port 6080 6099)"; then
          echo "oc-as: no free port in 6080-6099 for VNC" >&2
          exit 1
        fi
      else
        PORT="$PORT_REQ"
        if ! port_is_free "$PORT"; then
          echo "oc-as: port $PORT is already in use" >&2
          exit 1
        fi
      fi
      NAME="vnc_${PORT}_${REST}"
    fi
    MODE_FLAGS=(-p "127.0.0.1:${PORT}:6080" -e OC_VIEW=1)
    ;;
esac

# --- container/volume/host paths ---------------------------------------------
CONTAINER="oc-browser-${PROJTAG}-${NAME}"
VOLUME="oc-browser-home-${PROJTAG}-${NAME}"
HOST_SHARED="${VOLUME_ROOT}/${NAME}/shared"
HOST_MEDIA="${VOLUME_ROOT}/${NAME}/media"
IMAGE="${OC_IMAGE:-openclaw-browser:local}"

mkdir -p "$HOST_SHARED" "$HOST_MEDIA"
# Container 'oc' user is UID 1000. If the host dir owner ≠ 1000 (e.g. root host),
# the container can't write. Open the leaves to all so any host UID works.
chmod a+rwx "$HOST_SHARED" "$HOST_MEDIA" 2>/dev/null || true

ensure_running() {
  if docker inspect -f '{{.State.Running}}' "$CONTAINER" 2>/dev/null | grep -q true; then
    return
  fi
  if docker inspect "$CONTAINER" >/dev/null 2>&1; then
    docker start "$CONTAINER" >/dev/null
  else
    local run_args=(
      run -d --name "$CONTAINER"
      --shm-size=2g
      --cap-drop=ALL
      --security-opt=no-new-privileges
      -v "$VOLUME:/home/oc"
      -v "$HOST_SHARED:/home/oc/shared"
      -v "$HOST_MEDIA:/home/oc/.openclaw/media"
    )
    # Mode-derived flags (host: X mount + DISPLAY, vnc: port + OC_VIEW).
    if [ "${#MODE_FLAGS[@]}" -gt 0 ]; then
      run_args+=("${MODE_FLAGS[@]}")
    fi
    # Legacy: OC_VIEW=1 with the plain (no-prefix) mode keeps the old fixed-port
    # behaviour. Prefix mode wins; if MODE=vnc, we already injected the port.
    if [ "$MODE" = "plain" ] && [ "${OC_VIEW:-0}" = "1" ]; then
      run_args+=(-p 127.0.0.1:6080:6080 -e OC_VIEW=1)
    fi
    # Caller-provided extra docker run flags (e.g. GPU, memory). Word-split on
    # whitespace; flags with embedded spaces are not supported here.
    if [ -n "${OC_DOCKER_EXTRA:-}" ]; then
      # shellcheck disable=SC2206
      run_args+=( ${OC_DOCKER_EXTRA} )
    fi
    run_args+=("$IMAGE")
    docker "${run_args[@]}" >/dev/null
  fi

  for _ in $(seq 1 75); do
    if docker exec "$CONTAINER" curl -fsS http://127.0.0.1:18789/readyz >/dev/null 2>&1; then
      return
    fi
    sleep 0.2
  done

  echo "oc-as: gateway never became ready in $CONTAINER" >&2
  docker logs --tail 80 "$CONTAINER" >&2 || true
  exit 1
}

ensure_running

if [ "$MODE" = "vnc" ] && [ -n "$PORT" ]; then
  echo "oc-as: VNC at http://127.0.0.1:${PORT}/vnc.html" >&2
fi

DOCKER_FLAGS=(-i)
if [ -t 0 ] && [ -t 1 ]; then DOCKER_FLAGS=(-it); fi

exec docker exec "${DOCKER_FLAGS[@]}" "$CONTAINER" openclaw "$@"
